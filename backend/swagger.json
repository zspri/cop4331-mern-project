{
    "openapi": "3.0.0",
    "info": {
        "title": "Workout Tracker API",
        "version": "1.0.0",
        "description": "Local API documentation"
    },
    "servers": [
        {
            "url": "http://localhost:5001",
            "description": "Local development server"
        }
    ],
    "tags": [
        {
            "name": "Auth",
            "description": "Authentication routes"
        },
        {
            "name": "Test",
            "description": "Test route"
        }
    ],
    "paths": {
        "/api/ping": {
            "get": {
                "summary": "Test API",
                "description": "Checks whether the API is running",
                "tags": [
                    "Test"
                ],
                "responses": {
                    "200": {
                        "description": "API working",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "API is working"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/register": {
            "post": {
                "summary": "Register user",
                "description": "Creates a new user account",
                "tags": [
                    "Auth"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "firstName",
                                    "lastName",
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "firstName": {
                                        "type": "string",
                                        "example": "John"
                                    },
                                    "lastName": {
                                        "type": "string",
                                        "example": "Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "User registered successfully"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid input or user already exists"
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "summary": "Login user",
                "description": "Authenticates a user and returns a token",
                "tags": [
                    "Auth"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "example": {
                                    "token": "your_jwt_token_here",
                                    "user": {
                                        "id": "1234567890",
                                        "firstName": "John",
                                        "lastName": "Doe",
                                        "email": "john@example.com"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        }
    }
}